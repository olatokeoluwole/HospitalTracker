rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }

    function isDispensary() {
      return isAuthenticated() && getUserRole() == 'dispensary';
    }

    function isStore() {
      return isAuthenticated() && getUserRole() == 'store';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /drugs/{drugId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated(); 
      allow delete: if isAdmin();
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAuthenticated();
      allow create: if isDoctor();
      allow update: if isDispensary() || isDoctor() || isAdmin();
    }

    match /dispense_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isDispensary();
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
    }

    match /internal_transfers/{transferId} {
      allow read: if isAuthenticated();
      allow create: if isStore() || isAdmin();
    }

    match /staff_roles/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
